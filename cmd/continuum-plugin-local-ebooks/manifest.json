{
  "plugin_id": "continuum.local-ebooks",
  "version": "1.0.2",
  "checksum": "__CHECKSUM__",
  "continuum_api_version": "v1",
  "category": "Books/Ebooks",
  "supported_platforms": [
    {
      "os": "linux",
      "arch": "amd64"
    }
  ],
  "capabilities": [
    {
      "type": "ebook_backend.v1",
      "id": "local_ebooks",
      "display_name": "Local Ebooks Library",
      "description": "Scans local ebook, document, and future comic libraries and exposes them to the Ebooks portal.",
      "metadata": {
        "ebook_roles": [
          "library_source"
        ],
        "supports_catalog": true,
        "supports_requests": false,
        "supports_auto_monitoring": false
      }
    },
    {
      "type": "metadata_provider.v1",
      "id": "local_ebooks_meta",
      "display_name": "Local Ebooks metadata aggregator",
      "description": "Searches OpenLibrary, GoogleBooks, ISBNdb, Hardcover, Goodreads, Amazon, Anna's Archive, Project Gutenberg, BookBrainz, FantasticFiction, ISFDB, LibraryThing, Internet Archive, WorldCat, and Douban.",
      "metadata": {
        "default_priority": {
          "book": 1
        }
      }
    },
    {
      "type": "scheduled_task.v1",
      "id": "library_scan",
      "display_name": "Periodic library rescan",
      "cron": "0 */6 * * *",
      "description": "Walks configured ebook/document library directories and upserts discovered titles."
    },
    {
      "type": "scheduled_task.v1",
      "id": "metadata_enrichment_worker",
      "display_name": "Metadata enrichment worker",
      "cron": "* * * * *",
      "description": "Fills missing ebook metadata by querying the bundled aggregator providers."
    },
    {
      "type": "http_routes.v1",
      "id": "admin",
      "display_name": "Local Ebooks Admin",
      "description": "Admin UI for local ebook libraries, scans, metadata enrichment, and diagnostics."
    }
  ],
  "http_routes": [
    {
      "id": "assets",
      "method": "GET",
      "path": "/assets/*",
      "access": "public"
    },
    {
      "id": "file_api",
      "method": "GET",
      "path": "/api/v1/file/*",
      "access": "public"
    },
    {
      "id": "cover_api",
      "method": "GET",
      "path": "/api/v1/cover/*",
      "access": "public"
    },
    {
      "id": "catalog_public",
      "method": "GET",
      "path": "/catalog/*",
      "access": "public"
    },
    {
      "id": "api",
      "method": "*",
      "path": "/api/v1/*",
      "access": "authenticated"
    },
    {
      "id": "admin_root",
      "method": "GET",
      "path": "/admin",
      "access": "admin",
      "navigable": true,
      "navigation_label": "Local Ebooks",
      "navigation_kind": "admin"
    },
    {
      "id": "admin_sub",
      "method": "*",
      "path": "/admin/*",
      "access": "admin"
    }
  ],
  "global_config_schema": [
    {
      "key": "database_url",
      "title": "Postgres connection string",
      "description": "DSN for the dedicated Local Ebooks schema.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Connection URL",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true
          }
        ]
      }
    },
    {
      "key": "stream_signing_secret",
      "title": "Media signing secret",
      "description": "HMAC key shared with the ebooks portal's media_signing_secret. Must match exactly for signed cover and file URLs to validate.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": false,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "HMAC secret (base64-encoded recommended)",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "secret": true
          }
        ]
      }
    }
  ]
}
